# Production environment example

DATABASE_URL=postgres://user:password@db:5432/qfc_explorer
RPC_URL=http://qfc-node:8545
NEXT_PUBLIC_BASE_URL=https://explorer.example.com

INDEXER_POLL_INTERVAL_MS=10000
INDEXER_USE_FINALIZED=true
INDEXER_BLOCK_RETRIES=3
INDEXER_SKIP_ON_ERROR=false
INDEXER_RETRY_FAILED=true
INDEXER_HEALTH_MAX_AGE_MS=300000
