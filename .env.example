# QFC Explorer environment variables

# PostgreSQL connection string
# Example: postgres://user:password@localhost:5432/qfc_explorer
DATABASE_URL=

# RPC endpoint for QFC node
# Example: https://rpc.testnet.qfc.network
RPC_URL=

# Base URL for server-side API fetches
# Example: http://localhost:3000 or https://your-domain.com
NEXT_PUBLIC_BASE_URL=

# Optional: starting block height for the indexer
INDEXER_START_HEIGHT=

# Polling interval in milliseconds (set 0 to disable continuous polling)
INDEXER_POLL_INTERVAL_MS=

# Use finalized block height if available (default true)
INDEXER_USE_FINALIZED=

# Retries per block before failing or skipping (default 3)
INDEXER_BLOCK_RETRIES=

# Skip blocks after repeated failures (default false)
INDEXER_SKIP_ON_ERROR=

# Retain last failed block info in indexer_state (always on)
# Stored under key: failed_blocks
